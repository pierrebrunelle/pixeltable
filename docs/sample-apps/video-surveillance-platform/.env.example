# Required API keys
GEMINI_API_KEY=your-google-gemini-api-key
TWELVELABS_API_KEY=your-twelvelabs-api-key

# Optional model overrides (defaults shown)
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# TWELVELABS_MODEL=marengo3.0
# DETR_MODEL=facebook/detr-resnet-50-panoptic
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Pixeltable configuration (see https://docs.pixeltable.com/platform/configuration.md)
# PIXELTABLE_HOME=/data/pixeltable
# PIXELTABLE_INPUT_MEDIA_DEST=s3://your-bucket/input
# PIXELTABLE_OUTPUT_MEDIA_DEST=s3://your-bucket/output
# PIXELTABLE_FILE_CACHE_SIZE_G=50
